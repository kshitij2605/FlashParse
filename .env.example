# GLM Hybrid OCR Configuration

# VLM endpoint for image captioning/classification
# Any OpenAI-compatible API endpoint (vLLM, SGLang, TGI, OpenAI, etc.)
VLM_ENDPOINT=http://localhost:8008/v1/chat/completions
VLM_API_KEY=your-api-key-here
VLM_MODEL=your-vlm-model-name

# VLM tuning (optional)
# VLM_TEMPERATURE=0.0
# VLM_TOP_P=0.1
# VLM_MAX_TOKENS_CAPTION=2048
# VLM_MAX_CONCURRENCY=20
# VLM_TIMEOUT=120.0

# GLM-OCR vLLM server config
GLMOCR_CONFIG_PATH=glmocr_config.yaml

# API server
API_HOST=0.0.0.0
API_PORT=8000
